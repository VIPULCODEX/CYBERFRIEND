# .env – Configuration file for Cybersecurity Friend AI Assistant
# ⚠️  IMPORTANT: Never commit this file to version control (Git)!
#     Add ".env" to your .gitignore

# ─────────────────────────────────────────────────────
# REQUIRED: Google Gemini API Key
# Get it FREE at: https://aistudio.google.com/apikey
# ─────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ─────────────────────────────────────────────────────
# OPTIONAL: NewsAPI Key (for real-time cybersecurity news)
# Get it FREE at: https://newsapi.org/
# Free tier: 100 requests/day
# ─────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here
