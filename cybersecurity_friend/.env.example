# QuantX – Cybersecurity AI Assistant Configuration
# Copy this to .env and fill in your keys
#
# SECURITY: Never commit the .env file to version control!
# The .gitignore file already excludes it.

# ─── REQUIRED KEYS ─────────────────────────────────
# Original primary key
GROQ_API_KEY=your_groq_api_key_here

# (Optional) Add more keys here separated by commas to 3x/4x your capacity!
GROQ_API_KEYS=your_first_groq_key,your_second_groq_key,your_third_groq_key

# ─── OPTIONAL KEYS ─────────────────────────────────
NEWS_API_KEY=your_news_api_key_here          # Free from: https://newsapi.org/
GOOGLE_API_KEY=your_gemini_key_here          # Only if using Gemini instead of Groq
